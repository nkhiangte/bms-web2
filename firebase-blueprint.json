{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "warden", "parent", "pending"] },
        "studentIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "section": { "type": "string" },
        "rollNumber": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "aadhaarNumber": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "photographUrl": { "type": "string" }
      },
      "required": ["name", "grade"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Staff member record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "contact": { "type": "string" }
      },
      "required": ["name", "designation"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "Public news or announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "HSLCResultSummary": {
      "title": "HSLC Result Summary",
      "description": "Yearly HSLC performance statistics",
      "type": "object",
      "properties": {
        "year": { "type": "number" },
        "appeared": { "type": "number" },
        "passed": { "type": "number" },
        "passPercentage": { "type": "string" },
        "distinction": { "type": "number" },
        "firstDivision": { "type": "number" },
        "secondDivision": { "type": "number" },
        "thirdDivision": { "type": "number" },
        "distinctionListImageUrl": { "type": "string" }
      },
      "required": ["year", "appeared", "passed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff records"
    },
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Public news items"
    },
    "/hslc_results/{resultId}": {
      "schema": "HSLCResultSummary",
      "description": "Yearly HSLC results statistics"
    }
  }
}
